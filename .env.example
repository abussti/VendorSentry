# Shodan API key — free tier at https://shodan.io
SHODAN_API_KEY=your_shodan_key_here

# VirusTotal API key — free tier at https://virustotal.com
VT_API_KEY=your_virustotal_key_here

# Have I Been Pwned API key — paid subscription at https://haveibeenpwned.com
# Optional — platform runs without it, HIBP checks will be skipped
HIBP_API_KEY=your_hibp_key_here
